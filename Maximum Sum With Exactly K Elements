class Solution(object):
    def maximizeSum(self, nums, k):
        """
        :type nums: List[int]
        :type k: int
        :rtype: int
        """
        max_heap = [-x for x in nums]
        heapq.heapify(max_heap)
    
        score = 0
    
        for _ in range(k):
            m = -heapq.heappop(max_heap)  # get largest element
            score += m
            heapq.heappush(max_heap, -(m + 1))  # insert m+1
    
        return score
