class Solution(object):
    def findMissingElements(self, nums):
        """
        :type nums: List[int]
        :rtype: List[int]
        """
        num_set = set(nums)
        min_val = min(nums)
        max_val = max(nums)
        missing = []
    
        for num in range(min_val, max_val + 1):
            if num not in num_set:
                missing.append(num)
    
        return missing
