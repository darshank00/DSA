class Solution(object):
    def kthDistinct(self, arr, k):
        """
        :type arr: List[str]
        :type k: int
        :rtype: str
        """
        from collections import Counter
    
    
        freq = Counter(arr)
    
   
        count = 0
        for s in arr:
            if freq[s] == 1:
                count += 1
                if count == k:
                    return s
    
        return ""
